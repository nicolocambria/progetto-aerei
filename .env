# =============================================================================
# Configurazione della pipeline (12-factor: niente valori hardcoded nel codice)
# Questo file NON contiene segreti: adsb.fi non richiede API key.
# =============================================================================

# --- Sorgente dati ADS-B: adsbfi | airplaneslive | opensky ---
SOURCE=adsbfi

# --- Frequenza di polling dell'API (secondi). 30s è ampiamente nei rate limit ---
POLL_INTERVAL=30

# --- Area geografica monitorata: cerchio di raggio AREA_DIST_NM (miglia
#     nautiche) centrato su (AREA_LAT, AREA_LON). Default: Italia centrale,
#     centro Roma, raggio 250 nm ---
AREA_LAT=41.9
AREA_LON=12.5
AREA_DIST_NM=250

# --- Credenziali OpenSky (OPZIONALI, servono solo se SOURCE=opensky) ---
OPENSKY_USER=
OPENSKY_PASS=

# --- Soglie fisiche per gli alert rule-based e per le weak label del ML ---
ALT_MAX_FT=60000
SPEED_MAX_KT=700
VS_MAX_FPM=10000

# --- Geofence ("zona sorvegliata"): bounding box attorno all'aeroporto di
#     Roma Fiumicino (LIRF). Gli aerei in avvicinamento/decollo la attraversano
#     spesso, quindi l'alert GEOFENCE_ENTER è osservabile in demo.
#     (Il default della specifica era su Milano, ma è fuori dal raggio di
#     250 nm da Roma: non sarebbe mai scattato.) ---
GEO_LAT_MIN=41.75
GEO_LAT_MAX=41.85
GEO_LON_MIN=12.20
GEO_LON_MAX=12.30

# --- Soglie di probabilità per gli alert model-based (ML) ---
PROB_WARN=0.60
PROB_CRIT=0.85
